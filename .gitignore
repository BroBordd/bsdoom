# Packed plugin (generated by pack_bsdoom.py — never commit the packed file)
bsdoom.py

# Assets (large binaries, must not be committed)
*.so
*.WAD
*.wad
*.zip

# Extraction temp directories created by the plugin at runtime
.bsdoom_*/

# Build artifacts from doomgeneric
doomgeneric/*.o
doomgeneric/build_python/
doomgeneric/libdoomgeneric.so

# Doom frame snapshots
frame_*.png

# Runtime logs
bsdoom.log

# Python
__pycache__/
*.pyc
*.pyo

# macOS
.DS_Store

# editors
.vscode/
.idea/
*.swp
*.swo
